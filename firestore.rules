rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // User accounts, profile details, and earnings/balances for Quiz, Typing, and Ad View tasks
    match /users/{userId} {
      allow read, write: if true;
    }
    // System settings including referral, quiz_settings, typing_settings, and ad_settings
    match /settings/{documentId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == "its.me.calloftamim@gmail.com";
    }
    // Success notifications when a user earns rewards from Quiz, Typing, or Ad View
    match /notifications/{notificationId} {
      allow read, write: if true;
    }
    match /tasks/{taskId} {
      allow read, write: if true;
    }
    match /submissions/{submissionId} {
      allow read, write: if true;
    }
    match /history/{historyId} {
      allow read, write: if true;
    }
    match /balance/{userId} {
      allow read, write: if true;
    }
    match /drive_offers/{offerId} {
      allow read, write: if true;
    }
    match /drive_orders/{orderId} {
      allow read, write: if true;
    }
    match /micro_jobs/{jobId} {
      allow read, write: if true;
    }
    match /micro_job_submissions/{submissionId} {
      allow read, write: if true;
    }
    match /withdrawals/{withdrawalId} {
      allow read, write: if true;
    }
    match /deposits/{depositId} {
      allow read, write: if true;
    }
    match /transactions/{transactionId} {
      allow read, write: if true;
    }
    match /jobs/{jobId} {
      allow read, write: if true;
    }
    match /job_posts/{jobId} {
      allow read, write: if true;
    }
  }
}
